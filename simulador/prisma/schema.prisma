// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Character {
  id      Int    @id @default(autoincrement())
  name    String
  type    String  // "zombie" o "robot"
  health  Int
  attack  Int
  defense Int
  speed   Int
  //Las relaciones
  battles1  Battle[] @relation("character1")
  battles2  Battle[] @relation("character2")
  battlesWon Battle[] @relation("winner")
}

model Battle {
  id            Int       @id @default(autoincrement())
  character1Id  Int
  character2Id  Int
  winnerId      Int
  turns         Int
  //Las relaciones
  character1   Character @relation("character1", fields: [character1Id], references: [id])
  character2   Character @relation("character2", fields: [character2Id], references: [id])
  winner       Character @relation("winner",     fields: [winnerId],     references: [id])
}


